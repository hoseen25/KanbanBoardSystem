<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" prefWidth="800.0" prefHeight="600.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kanbanboardsystem.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Kanban Board System">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox spacing="10.0" alignment="CENTER">
        <TextField fx:id="titleInput" promptText="Task Title" prefWidth="200.0" />
        <TextField fx:id="descriptionInput" promptText="Task Description" prefWidth="300.0" />
        <Button text="Add Task" onAction="#onAddTaskClicked" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>

    <HBox spacing="15.0" VBox.vgrow="ALWAYS">

        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="To Do" textFill="#d32f2f">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <ListView fx:id="todoListView" VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="In Progress" textFill="#f57c00">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <ListView fx:id="inProgressListView" VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Done" textFill="#388e3c">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <ListView fx:id="doneListView" VBox.vgrow="ALWAYS" />
        </VBox>

    </HBox>
</VBox>